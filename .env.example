# Copy to .env and fill in. .env is git-ignored.

# OpenRouter — used by all chat-model evaluations (Experiments 1, 2, 4, 5).
# For the full paid sweep (configs/exp1.yaml, etc.), fund credits on your account;
# :free route daily caps do not apply to standard paid model IDs.
OPENROUTER_API_KEY=
OPENROUTER_REFERER=https://github.com/your-org/long-context-discourse
OPENROUTER_TITLE=EMNLP2026-Discourse-Survey

# Hugging Face — used by hf_upload helper and Experiment 3 (gated models).
HF_TOKEN=

# Optional: directly hit Anthropic for any baseline checks.
ANTHROPIC_API_KEY=
